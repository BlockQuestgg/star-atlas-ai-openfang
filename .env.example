# LLM Provider — Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# Community vault path (absolute path on host) — optional, mounted read-only
# COMMUNITY_VAULT_PATH=/path/to/community-vault

# Discord bot token — optional, commented out by default
# Setup: https://discord.com/developers/applications
#   1. Create application → add bot
#   2. Enable "Message Content Intent" under Privileged Gateway Intents
#   3. OAuth2 scopes: bot | Permissions: Send Messages, Read Message History
#   4. Copy bot token here
# DISCORD_BOT_TOKEN=
